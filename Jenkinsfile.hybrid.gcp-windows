                        withEnv(maestroEnvList()) {
                                bat """cd /d "${env.WORKSPACE}" && python scripts/jenkins_atp_stage.py all login "${params.APP_PACKAGE}" "${params.CLEAR_STATE.toString()}" "${params.MAESTRO_CMD}" """
                            }
                    }
                }
            }
        }

        stage('SignUp_Later') {
            when { expression { return params.RUN_ATP_SIGNUP_LATER } }
            agent { label params.DEVICES_AGENT }
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
