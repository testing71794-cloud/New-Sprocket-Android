// OPT-IN hybrid pipeline entrypoint (GCP orchestrator + Windows USB Maestro).
// Script Path: Jenkinsfile.hybrid.gcp-windows
// Keep TINY to avoid CPS MethodTooLarge. Body: jenkins/hybrid_gcp_windows_body.groovy
// See docs/DISTRIBUTED_GCP_WINDOWS_ARCHITECTURE.md

// Define job params BEFORE any node() — avoids mid-run properties() hangs ("Waiting for run to start").
properties([
    disableConcurrentBuilds(),
    buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '3')),
    parameters([
        string(name: 'GCP_ORCHESTRATOR_AGENT', defaultValue: 'built-in', description: 'Linux controller label for sh/GCP stages (usually built-in).'),
        string(name: 'DEVICES_AGENT', defaultValue: 'devices', description: 'Windows USB-phone agent label (devices, my-pc-devices, …). Agent must be Online.'),
        string(name: 'APP_PACKAGE', defaultValue: 'com.hp.impulse.sprocket', description: 'App package id'),
        string(name: 'MAESTRO_CMD', defaultValue: 'maestro.bat', description: 'Maestro launcher'),
        string(name: 'MAESTRO_HOME', defaultValue: '', description: 'Optional; empty = auto-detect'),
        string(name: 'ANDROID_HOME', defaultValue: '', description: 'Optional; empty = auto-detect'),
        string(name: 'JAVA_HOME_OVERRIDE', defaultValue: '', description: 'Optional; empty = auto-detect'),

        // Optional ATP stages (checkboxes) — same UX as earlier jobs
        booleanParam(name: 'RUN_ATP_SPLASH', defaultValue: true, description: 'ATP: splash'),
        booleanParam(name: 'RUN_ATP_ONBOARDING', defaultValue: true, description: 'ATP: onboarding'),
        booleanParam(name: 'RUN_ATP_SIGNUP', defaultValue: true, description: 'ATP: signup'),
        booleanParam(name: 'RUN_ATP_LOGIN', defaultValue: true, description: 'ATP: login'),
        booleanParam(name: 'RUN_ATP_SIGNUP_LATER', defaultValue: true, description: 'ATP: signup-later'),
        booleanParam(name: 'RUN_ATP_CONNECTION', defaultValue: false, description: 'ATP: connection'),
        booleanParam(name: 'RUN_ATP_PERMISSION', defaultValue: false, description: 'ATP: permission'),
        booleanParam(name: 'RUN_ATP_GALLERY', defaultValue: false, description: 'ATP: gallery'),
        booleanParam(name: 'RUN_ATP_QUICK_PRINT', defaultValue: false, description: 'ATP: quick-print'),
        booleanParam(name: 'RUN_ATP_COLLAGE', defaultValue: false, description: 'ATP: collage'),
        booleanParam(name: 'RUN_ATP_HOME', defaultValue: false, description: 'ATP: home'),
        booleanParam(name: 'RUN_ATP_CAMERA', defaultValue: false, description: 'ATP: camera'),
        booleanParam(name: 'RUN_ATP_EDITOR', defaultValue: false, description: 'ATP: editor'),
        booleanParam(name: 'RUN_ATP_PRINTING', defaultValue: false, description: 'ATP: printing'),
        booleanParam(name: 'RUN_ATP_PRECUT', defaultValue: false, description: 'ATP: precut'),
        booleanParam(name: 'RUN_ATP_VIDEO', defaultValue: false, description: 'ATP: video'),
        booleanParam(name: 'RUN_ATP_TILE_PRINT', defaultValue: false, description: 'ATP: tile-print'),
        booleanParam(name: 'RUN_ATP_SETTINGS', defaultValue: false, description: 'ATP: settings'),
        booleanParam(name: 'RUN_ATP_FIRMWARE', defaultValue: false, description: 'ATP: firmware'),
        booleanParam(name: 'RUN_ATP_AI', defaultValue: false, description: 'ATP: ai'),
        booleanParam(name: 'RUN_ATP_ALERTS', defaultValue: false, description: 'ATP: alerts'),
        booleanParam(name: 'RUN_ATP_GENERAL', defaultValue: false, description: 'ATP: general'),
        booleanParam(name: 'RUN_ATP_PHOTO_ID', defaultValue: false, description: 'ATP: photo-id'),
        booleanParam(name: 'RUN_ATP_PHOTOBOOTH', defaultValue: false, description: 'ATP: photobooth'),
        booleanParam(name: 'RUN_ATP_CUSTOM_SDK', defaultValue: false, description: 'ATP: custom-sdk'),
        booleanParam(name: 'RUN_ATP_ONBOARDING_SPLASH', defaultValue: false, description: 'ATP: onboarding-splash'),

        text(name: 'ATP_MODULES', defaultValue: '', description: 'Optional override list (comma-separated). Leave EMPTY to use the RUN_ATP_* checkboxes above.'),

        booleanParam(name: 'RUN_AI_ANALYSIS', defaultValue: true, description: 'OpenRouter probe + analysis'),
        booleanParam(name: 'SEND_FINAL_EMAIL', defaultValue: false, description: 'Send final email'),
        booleanParam(name: 'CLEAR_STATE', defaultValue: true, description: 'Clear app state'),
        string(name: 'OPENROUTER_CREDENTIALS_ID', defaultValue: 'OPENROUTER_API_KEY', description: 'Secret text credential ID'),
    ]),
])

echo "[hybrid] bootstrap on any free executor (not waiting for a fixed label)"
def body
// Unlabeled node = first free executor (controller or agent). Avoids queue stall on missing 'built-in' label.
node {
    echo "[hybrid] bootstrap node=${env.NODE_NAME} labels=${env.NODE_LABELS}"
    checkout scm
    body = load 'jenkins/hybrid_gcp_windows_body.groovy'
}
body.runHybrid()
