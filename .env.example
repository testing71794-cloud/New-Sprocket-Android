# Copy to .env (not committed) and set your key. Never commit .env.
# OpenRouter: get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Local Sprocket runs on Samsung only (optional — scripts default to RZCWA2B05RB):
# SPROCKET_DEVICE_SERIAL=RZCWA2B05RB
# Jenkins keeps Motorola via detected_devices.txt — do not change that for Jenkins jobs.
